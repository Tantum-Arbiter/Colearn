# Story Renderer Configuration
# Copy this to .env and update as needed

# Server (0.0.0.0 = accessible from network)
HOST=0.0.0.0
PORT=8000

# ComfyUI (runs on same machine)
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# Worker settings
RENDER_WORKERS=1
JOB_QUEUE_MAX=20

# Authentication (generate a secure key)
WORKER_API_KEY=your-secret-key-here

# Output directory
OUTPUT_DIR=./outputs

# Default model (must exist in ComfyUI/models/checkpoints/)
DEFAULT_MODEL=sd3.5_medium_incl_clips_t5xxlfp8scaled

