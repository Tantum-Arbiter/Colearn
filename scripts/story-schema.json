{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "story-data.schema.json",
  "title": "Story Data",
  "description": "Schema for story-data.json files",
  "type": "object",
  "required": ["id", "title", "category", "pages"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique story identifier (kebab-case)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "category": {
      "type": "string",
      "enum": ["personalized", "bedtime", "adventure", "nature", "friendship", "learning", "fantasy", "music", "activities", "growing"]
    },
    "coverImage": {
      "type": "string",
      "description": "Path to cover thumbnail"
    },
    "isAvailable": {
      "type": "boolean",
      "default": true
    },
    "ageRange": {
      "type": "string",
      "pattern": "^[0-9]+-[0-9]+$",
      "description": "Age range like 2-5"
    },
    "duration": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of pages"
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "localizedTitle": {
      "type": "object",
      "description": "Localized story titles for multi-language support",
      "properties": {
        "en": { "type": "string" },
        "pl": { "type": "string" },
        "es": { "type": "string" },
        "de": { "type": "string" },
        "fr": { "type": "string" },
        "it": { "type": "string" },
        "pt": { "type": "string" },
        "ja": { "type": "string" },
        "ar": { "type": "string" },
        "tr": { "type": "string" },
        "nl": { "type": "string" },
        "da": { "type": "string" },
        "la": { "type": "string" },
        "zh": { "type": "string" }
      }
    },
    "localizedDescription": {
      "type": "object",
      "description": "Localized story descriptions for multi-language support",
      "properties": {
        "en": { "type": "string" },
        "pl": { "type": "string" },
        "es": { "type": "string" },
        "de": { "type": "string" },
        "fr": { "type": "string" },
        "it": { "type": "string" },
        "pt": { "type": "string" },
        "ja": { "type": "string" },
        "ar": { "type": "string" },
        "tr": { "type": "string" },
        "nl": { "type": "string" },
        "da": { "type": "string" },
        "la": { "type": "string" },
        "zh": { "type": "string" }
      }
    },
    "isPremium": {
      "type": "boolean",
      "default": false
    },
    "isFree": {
      "type": "boolean",
      "default": false,
      "description": "Whether the story is free to download without subscription"
    },
    "isReferralReward": {
      "type": "boolean",
      "default": false,
      "description": "Whether the story is unlocked via share/referral"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "description": "Filter tags for story categorization. 15 children's genres available.",
      "items": {
        "type": "string",
        "enum": ["calming", "bedtime", "adventure", "learning", "music", "family-exercises", "imagination-games", "animals", "friendship", "nature", "fantasy", "counting", "emotions", "silly", "rhymes"]
      }
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "pageNumber", "text"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "pageNumber": {
            "type": "integer",
            "minimum": 0
          },
          "type": {
            "type": "string",
            "enum": ["cover", "story"]
          },
          "text": {
            "type": "string"
          },
          "localizedText": {
            "type": "object",
            "description": "Age-grouped localized page text. Keys are age groups (0-2, 2-4, 4-6). Values are localized text objects with language codes as keys.",
            "properties": {
              "0-2": {
                "type": "object",
                "properties": {
                  "en": { "type": "string" }, "pl": { "type": "string" }, "es": { "type": "string" },
                  "de": { "type": "string" }, "fr": { "type": "string" }, "it": { "type": "string" },
                  "pt": { "type": "string" }, "ja": { "type": "string" }, "ar": { "type": "string" },
                  "tr": { "type": "string" }, "nl": { "type": "string" }, "da": { "type": "string" },
                  "la": { "type": "string" }, "zh": { "type": "string" }
                }
              },
              "2-4": {
                "type": "object",
                "properties": {
                  "en": { "type": "string" }, "pl": { "type": "string" }, "es": { "type": "string" },
                  "de": { "type": "string" }, "fr": { "type": "string" }, "it": { "type": "string" },
                  "pt": { "type": "string" }, "ja": { "type": "string" }, "ar": { "type": "string" },
                  "tr": { "type": "string" }, "nl": { "type": "string" }, "da": { "type": "string" },
                  "la": { "type": "string" }, "zh": { "type": "string" }
                }
              },
              "4-6": {
                "type": "object",
                "properties": {
                  "en": { "type": "string" }, "pl": { "type": "string" }, "es": { "type": "string" },
                  "de": { "type": "string" }, "fr": { "type": "string" }, "it": { "type": "string" },
                  "pt": { "type": "string" }, "ja": { "type": "string" }, "ar": { "type": "string" },
                  "tr": { "type": "string" }, "nl": { "type": "string" }, "da": { "type": "string" },
                  "la": { "type": "string" }, "zh": { "type": "string" }
                }
              }
            },
            "additionalProperties": false
          },
          "backgroundImage": {
            "type": "string",
            "description": "Asset path reference"
          },
          "characterImage": {
            "type": "string",
            "description": "Asset path reference"
          },
          "interactionType": {
            "type": "string",
            "enum": ["none", "interactive_state_change", "music_challenge", "jigsaw_puzzle", "reading_challenge"],
            "description": "Interaction type for this page"
          },
          "interactiveElements": {
            "type": "array",
            "description": "Interactive elements (reveal, toggle, drag) on this page",
            "items": {
              "type": "object",
              "required": ["id", "type", "image", "position", "size"],
              "properties": {
                "id": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": ["reveal", "toggle", "drag"]
                },
                "image": {
                  "type": "string",
                  "description": "Asset path for the interactive element image"
                },
                "position": {
                  "type": "object",
                  "required": ["x", "y"],
                  "properties": {
                    "x": { "type": "number", "minimum": 0, "maximum": 1 },
                    "y": { "type": "number", "minimum": 0, "maximum": 1 }
                  }
                },
                "size": {
                  "type": "object",
                  "required": ["width", "height"],
                  "properties": {
                    "width": { "type": "number", "minimum": 0, "maximum": 1 },
                    "height": { "type": "number", "minimum": 0, "maximum": 1 }
                  }
                },
                "hitArea": {
                  "type": "object",
                  "properties": {
                    "x": { "type": "number", "minimum": 0, "maximum": 1 },
                    "y": { "type": "number", "minimum": 0, "maximum": 1 },
                    "width": { "type": "number", "minimum": 0, "maximum": 1 },
                    "height": { "type": "number", "minimum": 0, "maximum": 1 }
                  }
                }
              }
            }
          },
          "musicChallenge": {
            "type": "object",
            "description": "Music challenge configuration for this page",
            "required": ["enabled", "instrumentId", "promptText", "mode", "autoPlaySuccessSong", "allowSkip", "micRequired", "fallbackAllowed", "hintLevel"],
            "properties": {
              "enabled": { "type": "boolean" },
              "instrumentId": { "type": "string", "description": "References a registered instrument asset" },
              "promptText": { "type": "string", "description": "Narrative prompt for the music challenge" },
              "mode": {
                "type": "string",
                "enum": ["guided", "free_play_optional"]
              },
              "songId": { "type": "string", "description": "References a practice song by ID from the song registry (preferred over requiredSequence)" },
              "requiredSequence": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Explicit note sequence (optional if songId is provided)"
              },
              "successSongId": { "type": "string", "description": "Legacy -no longer used" },
              "successStateId": { "type": "string", "description": "Optional page state change on success" },
              "autoPlaySuccessSong": { "type": "boolean" },
              "allowSkip": { "type": "boolean" },
              "micRequired": { "type": "boolean" },
              "fallbackAllowed": { "type": "boolean" },
              "hintLevel": {
                "type": "string",
                "enum": ["none", "minimal", "standard", "verbose"]
              }
            }
          },
          "jigsawPuzzle": {
            "type": "object",
            "description": "Jigsaw puzzle configuration for this page",
            "required": ["enabled", "gridSize", "promptText", "allowSkip"],
            "properties": {
              "enabled": { "type": "boolean" },
              "gridSize": {
                "type": "string",
                "enum": ["2x2", "4x4"],
                "description": "Grid dimensions: 2x2 (easy), 4x4 (medium/hard)"
              },
              "promptText": { "type": "string", "description": "Narrative prompt for the jigsaw puzzle" },
              "allowSkip": { "type": "boolean" }
            }
          },
          "readingChallenge": {
            "type": "object",
            "description": "Reading challenge configuration for this page",
            "required": ["enabled", "mode", "promptText", "allowSkip"],
            "properties": {
              "enabled": { "type": "boolean" },
              "mode": {
                "type": "string",
                "enum": ["fill_in_blank", "spell_word"],
                "description": "Challenge mode: fill_in_blank (tap missing words in order) or spell_word (select letters to spell a word)"
              },
              "promptText": { "type": "string", "description": "Narrative prompt for the reading challenge" },
              "allowSkip": { "type": "boolean" },
              "blankWordIndices": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0 },
                "description": "Zero-based indices of words in page text to blank out (fill_in_blank mode)"
              },
              "targetWord": {
                "type": "string",
                "description": "The word the user must spell (spell_word mode)"
              },
              "distractorLetters": {
                "type": "array",
                "items": { "type": "string", "maxLength": 1 },
                "description": "Extra letters added to the letter pool as distractors (spell_word mode)"
              }
            }
          }
        }
      }
    }
  }
}

